rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function emailVerified() {
      return request.auth.token.email_verified == true;
    }

    // Validation Blueprints
    function isValidExpense(data) {
      return data.keys().hasAll(['description', 'amount', 'date', 'category', 'userId', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 8
        && data.description is string && data.description.size() <= 500
        && data.amount is number && data.amount >= 0
        && data.date is string && data.date.size() <= 20
        && data.category in ['Food', 'Transport', 'Utilities', 'Entertainment', 'Health', 'Shopping', 'Other']
        && data.userId == request.auth.uid
        && data.aiCategorized is bool
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidExpenseUpdate(data) {
      return data.description is string && data.description.size() <= 500
        && data.amount is number && data.amount >= 0
        && data.date is string && data.date.size() <= 20
        && data.category in ['Food', 'Transport', 'Utilities', 'Entertainment', 'Health', 'Shopping', 'Other']
        && data.userId == existing().userId
        && data.createdAt == existing().createdAt
        && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().email == request.auth.token.email
        && incoming().createdAt == request.time;
      
      match /expenses/{expenseId} {
        allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow get: if isOwner(userId);
        
        allow create: if isOwner(userId) 
          && isValidId(expenseId)
          && isValidExpense(incoming());
          
        allow update: if isOwner(userId)
          && isValidExpenseUpdate(incoming())
          && incoming().diff(existing()).affectedKeys().hasOnly(['description', 'amount', 'date', 'category', 'updatedAt', 'aiCategorized']);
          
        allow delete: if isOwner(userId);
      }
    }
  }
}
